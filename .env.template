# =============================================================================
# Discord DM Auto-Responder — Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to the repository!
# For GitHub Actions, add these as repository secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Discord Authentication
# -----------------------------------------------------------------------------
# Your Discord USER token (for reading your DMs)
# ⚠️ Self-botting violates Discord ToS — use at your own risk
DISCORD_TOKEN=your_discord_user_token_here

# Your Discord BOT token (optional, for bot-based notifications)
BOT_TOKEN=your_bot_token_here

# Your Discord user ID (to identify which messages are yours vs others)
NOTIFY_USER_ID=your_discord_user_id_here

# -----------------------------------------------------------------------------
# Polling & Timing
# -----------------------------------------------------------------------------
# How often to check for new DMs (seconds) — used for local testing only
# GitHub Actions uses cron schedule instead
CHECK_INTERVAL=5

# Random delay range (seconds) before sending approved replies
# Makes replies feel more natural/human
AUTO_REPLY_DELAY_MIN=30
AUTO_REPLY_DELAY_MAX=120

# Max messages to fetch from conversation history for AI context
MAX_HISTORY_MESSAGES=100

# Hours before a pending suggestion auto-expires (0 = never expire)
SUGGESTION_EXPIRY_HOURS=24

# -----------------------------------------------------------------------------
# AI Configuration
# -----------------------------------------------------------------------------
# API key for AI provider (OpenRouter, OpenAI, or any compatible endpoint)
OLLAMA_API_KEY=your_ai_api_key_here

# Base URL for OpenAI-compatible API
# OpenRouter:  https://openrouter.ai/api/v1
# OpenAI:      https://api.openai.com/v1
# Local Ollama: http://localhost:11434/v1
AI_BASE_URL=https://openrouter.ai/api/v1

# Model to use for reply generation
AI_MODEL=meta-llama/llama-3.1-8b-instruct

# Temperature for reply generation (0.0 = deterministic, 1.0 = creative)
AI_TEMPERATURE=0.8

# Max tokens for generated replies
AI_MAX_TOKENS=256

# -----------------------------------------------------------------------------
# GitHub Gist Storage (shared state between Actions and mobile app)
# -----------------------------------------------------------------------------
# Gist ID — create a gist at https://gist.github.com with empty files:
#   queue.json  (content: {})
#   state.json  (content: {})
GIST_ID=your_gist_id_here

# GitHub Personal Access Token with 'gist' scope
GH_PAT=your_github_pat_here

# -----------------------------------------------------------------------------
# Optional: Contact Filtering
# -----------------------------------------------------------------------------
# Comma-separated Discord user IDs to monitor (empty = monitor all DMs)
WHITELIST_USER_IDS=

# Comma-separated Discord user IDs to ignore
BLACKLIST_USER_IDS=
